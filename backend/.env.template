# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS - NEON
# ===========================================
# Usa este connection string tanto para desarrollo local como producción
# La BD estará siempre en Neon (nube), tu backend local se conecta a ella
#
# Obtén tu connection string del dashboard de Neon:
# 1. Ve a neon.tech e inicia sesión
# 2. Selecciona tu proyecto
# 3. Copia el "Connection string" (pooler o directo)
# 4. Pégalo abajo reemplazando el valor

DB_CONNECTION_STRING=postgresql://username:password@ep-xxx-xxx.region.aws.neon.tech/database?sslmode=require

# ===========================================
# SEGURIDAD - JWT
# ===========================================
# Cambia esto por una clave secreta fuerte en producción
# Usa al menos 32 caracteres aleatorios
JWT_SECRET=tu_clave_secreta_muy_segura_aqui

# ===========================================
# PUERTO DEL SERVIDOR
# ===========================================
# Puerto donde correrá el backend localmente
# Usa 3001 para evitar conflictos con otras apps
PORT=3001

# ===========================================
# ENTORNO
# ===========================================
# development - Para trabajar local (más logs, synchronize activado)
# production - Para despliegue (menos logs, optimizado)
NODE_ENV=development
